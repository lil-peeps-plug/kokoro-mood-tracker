# --- Frontend (public, ships to the browser) ---
# Vite only exposes variables that start with VITE_ to your React code.
# These are NOT secret — anyone can read them in the browser. That's fine because
# they're protected by RLS on the server side.
#
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored; `.env.example` is committed as a template.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# --- Server side secrets (NEVER put real values in any file in this repo) ---
# These live as secrets on Supabase, configured via the Supabase CLI:
#     npx supabase secrets set BOT_SECRET=<your-token>
# The frontend never sees them. Listed here only as documentation of which
# names the Edge Function will read at runtime.
#   BOT_SECRET                 = Telegram bot token from @BotFather (Phase 2)
#   SUPABASE_SERVICE_ROLE_KEY  = auto-injected by Supabase, no manual setup
